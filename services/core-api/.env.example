# Core API Configuration

PORT=5000
DATABASE_URL="postgresql://postgres:password@localhost:5432/votosi?schema=public"
JWT_SECRET="generate_a_random_jwt_secret_key_here"

# Cloudinary Integration (for profile picture uploads)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Mailer Settings (for activation pin delivery)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
